# ─── App ──────────────────────────────────────────────────────────────────
PUBLIC_APP_URL=http://localhost:4420
PUBLIC_APP_NAME=Recast

# ─── Database (Neon / any Postgres) ───────────────────────────────────────
# Connection pooling URL recommended (Neon "pooled" URL works fine with
# the `postgres` driver since we set prepare:false in src/lib/db/index.ts).
DATABASE_URL=postgresql://user:password@localhost:5432/recast

# ─── Better Auth ──────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-byte-random-string
# Public URL the app is served from. In prod, must match the deployed origin.
BETTER_AUTH_URL=http://localhost:5173

# ─── OAuth providers (optional — leave blank to hide the social buttons) ─
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Polar (billing — Merchant of Record) ─────────────────────────────────
# Use "sandbox" while testing, "production" once Polar org is verified.
POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
# Product IDs created in your Polar dashboard (one per plan).
POLAR_PRODUCT_ID_PRO=
