{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "recast",
  "version": "0.0.1",
  "identifier": "com.nexonauts.recast",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:4000",
    "beforeDevCommand": "bun run ui:dev",
    "beforeBuildCommand": "bun run ui:build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Recast",
        "url": "/",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "maximizable": true,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}