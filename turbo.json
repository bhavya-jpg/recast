{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "prepare": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "prepare"]
    },
    "check": {
      "dependsOn": ["^build", "prepare"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}