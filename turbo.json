{
  "$schema": "https://v2-9-14.turborepo.dev/schema.json",
  "tasks": {
    "prepare": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "prepare"]
    },
    "check": {
      "dependsOn": ["^build", "prepare"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}